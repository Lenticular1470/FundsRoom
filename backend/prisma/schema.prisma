generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ChallanItem {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  challanId    String    @map("challan_id") @db.Uuid
  productId    String?   @map("product_id") @db.Uuid
  productName  String    @map("product_name") @db.VarChar(150)
  sku          String    @db.VarChar(100)
  category     String    @db.VarChar(100)
  price        Decimal   @db.Decimal(10, 2)
  quantity     Int
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  challan      Challan   @relation(fields: [challanId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_item_challan")
  product      Product?  @relation(fields: [productId], references: [id], onUpdate: NoAction, map: "fk_item_product")

  @@map("challan_items")
  @@index([challanId], map: "idx_challan_items_challan")
  @@index([productId], map: "idx_challan_items_product")
}

model Challan {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  challanNumber String         @unique @map("challan_number") @db.VarChar(50)
  customerId   String          @map("customer_id") @db.Uuid
  status       ChallanStatus?  @default(DRAFT)
  createdById  String          @map("created_by_id") @db.Uuid
  createdAt    DateTime?       @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime?       @default(now()) @map("updated_at") @db.Timestamp(6)
  items        ChallanItem[]
  customer     Customer        @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_challan_customer")
  createdBy    User            @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_challan_user")

  @@map("challans")
  @@index([customerId], map: "idx_challan_customer")
  @@index([status], map: "idx_challan_status")
}

model Customer {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String      @db.VarChar(100)
  businessName  String?     @map("business_name") @db.VarChar(150)
  gst           String?     @db.VarChar(20)
  phone         String      @db.VarChar(20)
  email         String?     @db.VarChar(255)
  type          CustomerType
  status        CustomerStatus
  address       String?
  followUpDate  DateTime?   @map("follow_up_date") @db.Timestamp(6)
  notes         String?
  support       String?
  createdAt     DateTime?   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime?   @default(now()) @map("updated_at") @db.Timestamp(6)
  challans      Challan[]

  @@map("customers")
  @@index([name], map: "idx_customer_name")
  @@index([phone], map: "idx_customer_phone")
}

model Product {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String          @db.VarChar(150)
  sku             String          @unique @db.VarChar(100)
  category        String          @db.VarChar(100)
  price           Decimal         @db.Decimal(10, 2)
  currentStock    Int?            @default(0) @map("current_stock")
  minimumStock    Int?            @default(0) @map("minimum_stock")
  warehouse       String?         @db.VarChar(100)
  createdAt       DateTime?       @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime?       @default(now()) @map("updated_at") @db.Timestamp(6)
  items           ChallanItem[]
  stockMovements  StockMovement[]

  @@map("products")
  @@index([sku], map: "idx_product_sku")
}

model StockMovement {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String             @map("product_id") @db.Uuid
  quantity     Int
  movementType StockMovementType  @map("movement_type")
  reason       String
  createdById  String             @map("created_by_id") @db.Uuid
  createdAt    DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  product      Product            @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_stock_product")
  createdBy    User               @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_stock_user")

  @@map("stock_movements")
  @@index([productId], map: "idx_stock_product")
  @@index([createdById], map: "idx_stock_user")
}

model User {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String          @db.VarChar(100)
  email          String          @unique @db.VarChar(255)
  password       String
  role           Role            @default(USER)
  createdAt      DateTime?       @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime?       @default(now()) @map("updated_at") @db.Timestamp(6)
  challans       Challan[]
  stockMovements StockMovement[]

  @@map("users")
}

enum ChallanStatus {
  DRAFT
  CONFIRMED
  CANCELLED

  @@map("challan_status")
}

enum CustomerStatus {
  LEAD
  ACTIVE
  INACTIVE

  @@map("customer_status")
}

enum CustomerType {
  RETAIL
  WHOLESALE
  DISTRIBUTOR

  @@map("customer_type")
}

enum Role {
  ADMIN
  USER
  SALES
  WAREHOUSE
  ACCOUNTS

  @@map("role")
}

enum StockMovementType {
  IN
  OUT

  @@map("stock_movement_type")
}
